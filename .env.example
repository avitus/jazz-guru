# --- LLM ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-5
# Must stay <= 21333 for non-streaming. Raise only if complete() is migrated
# to client.messages.stream(...) — see tests/unit/test_llm_config_contract.py.
ANTHROPIC_MAX_TOKENS=16000

# --- Embeddings ---
# Provider cascade: "auto" tries voyage -> ollama -> hash-stub (with a loud
# warning if it lands on hash). Pin to "voyage", "ollama", or "hash" to disable
# the cascade. Embedding dim is shared across providers and matched at the DB
# layer — voyage-3 and mxbai-embed-large are both 1024d, so no migration needed.
EMBEDDING_PROVIDER=auto
EMBEDDING_DIM=1024

# Voyage (hosted; free tier ~200M tok/mo). Leave key blank to skip in auto mode.
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-3

# Ollama (local). Install via: brew install ollama && brew services start ollama
# Then: ollama pull mxbai-embed-large
OLLAMA_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=mxbai-embed-large

# --- Database (local Postgres, no password) ---
# Default: connects as your $USER to a database named jazz_guru on localhost:5432
DATABASE_URL=postgresql+asyncpg:///jazz_guru
DATABASE_URL_SYNC=postgresql+psycopg:///jazz_guru

# --- Redis (optional; only needed for the background worker) ---
# Leave blank to disable async distillation; CLI/server still work via --sync
REDIS_URL=redis://localhost:6379/0

# --- Workspace / state ---
JG_DATA_DIR=./data
JG_STATE_DIR=./workspace/state
JG_TRACE_DIR=./workspace/traces
JG_WORKSPACE_DIR=./workspace

# --- Goal / config ---
JG_GOAL_FILE=./config/goal.md
JG_GOAL_YAML=./config/goal.yaml
JG_POLICY_FILE=./config/policy.yaml

# --- Web search (optional) ---
TAVILY_API_KEY=

# --- Music / audio ---
# On macOS Homebrew: brew install fluid-synth (binary) and a soundfont
FLUIDSYNTH_SOUNDFONT=

# Where SFZ libraries live for the sfizz/liquidsfz engines. Relative `library`
# paths in data/instruments.yaml resolve against this dir.
JG_INSTRUMENTS_FILE=./data/instruments.yaml
JG_INSTRUMENTS_ROOT=

# Extra paths the agent is allowed to read (resolve_in_safe).
# Comma-separated absolute paths; defaults to []. JG_DATA_DIR is always allowed.
JG_SAFE_EXTRA_PATHS=

# Opt-in OS sandbox for shell/python_exec/dynamic-tool subprocesses.
# Set to 1 to wrap them in `sandbox-exec -f data/sandbox/jg.sb` on macOS.
JG_OS_SANDBOX=0

# --- Music backend selection ---
# Each role can be "none" (disable) or the name of a backend adapter in
# src/jazz_guru/music/. Specialised backends lazy-import their dependency
# and become warnings rather than errors when the dep is not installed.
# Recommended order to enable as you install optional deps:
#   1. MUSIC_TRANSCRIPTION_BACKEND=basic_pitch   (pip install 'basic-pitch>=0.4')
#   2. MUSIC_ANALYSIS_BACKEND=omnizart            (pip install omnizart)  -> chord/beat
#   3. MUSIC_UNDERSTANDING_BACKEND=music_flamingo (Phase 2)
#   4. MUSIC_GENERATION_BACKEND=magenta_rt|elevenlabs_music (Phase 3)
MUSIC_TRANSCRIPTION_BACKEND=none
MUSIC_ANALYSIS_BACKEND=librosa
MUSIC_UNDERSTANDING_BACKEND=none
MUSIC_GENERATION_BACKEND=none

# MT3 has no stable Python API. If you have a CLI wrapper installed
# (binary or shell script that takes `--input <audio> --output <midi>`),
# point this at it. Leave blank to let the adapter try `import mt3.inference`.
# JG_MT3_CLI_TIMEOUT_SEC bounds the CLI invocation (kill + non-zero exit
# on timeout) so a hung child can't wedge the agent loop.
JG_MT3_CLI=
JG_MT3_CLI_TIMEOUT_SEC=600

# Music Flamingo (NVIDIA Audio Flamingo 3) — Hugging Face model id and
# instruction prompt. `-hf` is the base, `-chat` is the instruction-tuned
# variant. The first call downloads several GB from HF.
MUSIC_FLAMINGO_MODEL=nvidia/audio-flamingo-3-hf
MUSIC_FLAMINGO_MAX_NEW_TOKENS=256

# Magenta RealTime — like MT3, no stable Python API. If you have a CLI
# wrapper (`<cli> --prompt <text> --duration <sec> --output <wav>`),
# point this at it. Leave blank to let the adapter try `import magenta_rt`.
# JG_MAGENTA_RT_CLI_TIMEOUT_SEC bounds the CLI invocation similarly to MT3.
JG_MAGENTA_RT_CLI=
JG_MAGENTA_RT_CLI_TIMEOUT_SEC=300

# ElevenLabs Music — hosted generation. Sign up at https://elevenlabs.io,
# then paste your API key. ELEVENLABS_MUSIC_MODEL pins a specific model id.
ELEVENLABS_API_KEY=
ELEVENLABS_MUSIC_MODEL=music_v1

# --- Feature flags ---
FEATURE_TTS=0
FEATURE_AUDIO_ML=0

# --- Server ---
JG_HOST=127.0.0.1
JG_PORT=8000

# --- Telemetry ---
OTEL_SERVICE_NAME=jazz-guru
OTEL_EXPORTER_OTLP_ENDPOINT=
