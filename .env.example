# --- LLM ---
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_KEY_HERE
ANTHROPIC_MODEL=claude-sonnet-4-5
ANTHROPIC_MAX_TOKENS=8192

# --- Embeddings (Voyage AI by default) ---
# Leave blank to use the deterministic local hash-stub provider
VOYAGE_API_KEY=
EMBEDDING_PROVIDER=voyage
EMBEDDING_MODEL=voyage-3
EMBEDDING_DIM=1024

# --- Database (local Postgres, no password) ---
# Default: connects as your $USER to a database named jazz_guru on localhost:5432
DATABASE_URL=postgresql+asyncpg:///jazz_guru
DATABASE_URL_SYNC=postgresql+psycopg:///jazz_guru

# --- Redis (optional; only needed for the background worker) ---
# Leave blank to disable async distillation; CLI/server still work via --sync
REDIS_URL=redis://localhost:6379/0

# --- Workspace / state ---
JG_WORKSPACE_DIR=./workspace
JG_STATE_DIR=./workspace/state
JG_TRACE_DIR=./workspace/traces

# --- Goal / config ---
JG_GOAL_FILE=./config/goal.md
JG_GOAL_YAML=./config/goal.yaml
JG_POLICY_FILE=./config/policy.yaml

# --- Web search (optional) ---
TAVILY_API_KEY=

# --- Music / audio ---
# On macOS Homebrew: brew install fluid-synth (binary) and a soundfont
FLUIDSYNTH_SOUNDFONT=

# --- Feature flags ---
FEATURE_TTS=0
FEATURE_AUDIO_ML=0

# --- Server ---
JG_HOST=127.0.0.1
JG_PORT=8000

# --- Telemetry ---
OTEL_SERVICE_NAME=jazz-guru
OTEL_EXPORTER_OTLP_ENDPOINT=
